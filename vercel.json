{
  "installCommand": "npm install && cd frontend && npm install",
  "buildCommand": "cd frontend && npx vite build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/chat", "destination": "/api/chat" },
    { "source": "/generate-report", "destination": "/api/generate-report" },
    { "source": "/upload-video", "destination": "/api/upload-video" },
    { "source": "/hashtags/suggest", "destination": "/api/hashtags-suggest" }
  ]
}
